{
  "expo": {
    "name": "Street Explorer",
    "slug": "street-explorer",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "street-explorer",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.kaltenor.streetexplorer",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Street Explorer uses your location to record walks and draw your exploration map.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Street Explorer can keep recording an active exploration while the app is locked.",
        "UIBackgroundModes": [
          "location"
        ]
      }
    },
    "android": {
      "package": "com.kaltenor.streetexplorer",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "plugins": [
      "expo-sqlite"
    ]
  }
}
